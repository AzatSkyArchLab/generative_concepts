# AI render — copy this file to .env.local and fill in your keys.
# .env.local is gitignored. The Vite dev server / build will pick
# these up automatically and expose them to the browser as
# import.meta.env.VITE_*.

# Google Gemini direct (image generation models):
#   https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# OpenRouter (any model, including google/gemini-* image variants):
#   https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=
